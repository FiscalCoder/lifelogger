{
  "name": "lifelogger-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:init": "tsx scripts/migrate.ts init",
    "db:migrate": "tsx scripts/migrate.ts migrate",
    "db:migrate:status": "tsx scripts/migrate.ts status",
    "db:migrate:check": "tsx scripts/migrate.ts check",
    "db:new": "drizzle-kit generate --custom"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@types/pg": "^8.11.6",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.23.0",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.4.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
