<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════════════════════════════
         PERMISSIONS
         Primary target: Android 11 (API 30) — Qin F21 Pro.
         All permissions are compatible with API 31–35 unless capped with
         android:maxSdkVersion.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Microphone access for VAD sampling and audio recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Required to call startForeground() -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 12+ (API 31+): required for foreground services that use the mic.
         Silently ignored on API 30. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- PARTIAL_WAKE_LOCK: keeps CPU alive when screen is off (F4 requirement) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Allows BootReceiver to start on device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network access for chunk upload -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- External storage: only needed on Android ≤ 9 (API ≤ 29).
         API 30+ uses app-internal storage (getFilesDir()) which needs no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LifeLogger"
        android:usesCleartextTraffic="true">
        <!--
            usesCleartextTraffic=true: permits HTTP to the local server on the same WiFi.
            When the backend moves to HTTPS, remove this flag and add a
            network_security_config.xml that allows HTTPS only.
        -->

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|uiMode"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            LifeLoggerService: the foreground service that holds the mic.

            foregroundServiceType="microphone":
              Required on API 29+. On API 31+, must match the type passed to
              startForeground(), which ServiceCompat handles for us.

            android:stopWithTask="false":
              Service continues when the user swipes the app away from recents.
              Critical for 24/7 recording use case.
        -->
        <service
            android:name=".LifeLoggerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false" />

        <!--
            BootReceiver: starts LifeLoggerService on device reboot.
            android:exported="true" required for implicit system broadcasts on API 31+.
        -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
