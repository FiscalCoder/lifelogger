<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Recording state indicator ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/indicator_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_indicator" />

            <TextView
                android:id="@+id/tv_recording_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Stopped"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── Recording toggle ── -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_recording"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/label_recording"
            app:showText="false" />

        <TextView
            android:id="@+id/tv_chunk_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="?android:attr/textColorSecondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider" />

        <!-- ── WiFi status + upload now ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_wifi_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_wifi_checking"
                android:textAppearance="?attr/textAppearanceBody1" />

            <Button
                android:id="@+id/btn_upload_now"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_upload_now" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider" />

        <!-- ── Queue stats ── -->
        <TextView
            android:id="@+id/tv_pending_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_pending_uploads"
            android:textAppearance="?attr/textAppearanceBody1" />

        <TextView
            android:id="@+id/tv_failed_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/label_failed_uploads"
            android:textAppearance="?attr/textAppearanceBody1" />

        <TextView
            android:id="@+id/tv_uploaded_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/label_uploaded"
            android:textAppearance="?attr/textAppearanceBody1" />

        <TextView
            android:id="@+id/tv_last_upload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/label_last_upload"
            android:textAppearance="?attr/textAppearanceBody2" />

        <!-- Retry failed button — shown only when there are failed chunks -->
        <Button
            android:id="@+id/btn_retry_failed"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/action_retry_failed"
            android:textColor="@color/error"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider" />

        <!-- ── Power-saver mode toggle ── -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_power_saver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_power_saver"
            app:showText="false" />

    </LinearLayout>
</ScrollView>
